# VerdaTraceAI Configuration Environment Variables

# AlloyDB Database Integration Flag
USE_ALLOYDB=False
# Keep real database credentials in Secret Manager or local backend/.env only.
ALLOYDB_URI=

# Google Cloud Platform config
GCP_PROJECT_ID=your-gcp-project-id
VERTEX_REGION=us-central1

# Multi-LLM Agnostic config (options: vertex-ai, openai, anthropic)
LLM_PROVIDER=vertex-ai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Comma-separated allowed origins. Use exact domains in production.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
